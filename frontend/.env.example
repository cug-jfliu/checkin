# 环境变量示例文件（可提交到 Git）
#
# 前端根据运行模式自动加载对应的 .env 文件：
#   开发环境（vite dev）  → .env.development   VITE_API_BASE_URL=http://localhost:3000/api
#   生产环境（vite build）→ .env.production     VITE_API_BASE_URL=/api
#
# 使用方法：
#   cp .env.example .env.development   # 本地开发
#   cp .env.example .env.production    # 按需修改生产地址

VITE_API_BASE_URL=http://localhost:3000/api
